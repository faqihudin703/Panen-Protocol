{
  "apps": [
    {
      "name": "panen-model",
      "script": "./venv/bin/uvicorn",
      "args": "model_server:app --host 0.0.0.0 --port 5049 --workers 2",
      "interpreter": "none",
      "cwd": "/path/to/ai",
      "autorestart": true,
      "max_memory_restart": "512M",
      "out_file": "./log/panen-model.out.log",
      "error_file": "./log/panen-model.err.log"
    },
    {
      "name": "panen-relay-telegram",
      "script": "./venv/bin/uvicorn",
      "args": "relay_server:app --host 0.0.0.0 --port 5050 --workers 2",
      "interpreter": "none",
      "cwd": "/path/to/ai",
      "autorestart": true,
      "max_memory_restart": "256M",
      "out_file": "./log/panen-relay.out.log",
      "error_file": "./log/panen-relay.err.log"
    }
  ]
}
