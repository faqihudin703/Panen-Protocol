# Panen Protocol — Frontend Environment
# Copy ke .env dan isi sesuai setup
# JANGAN commit file .env ke GitHub

# ── Cluster ───────────────────────────────────────────────
VITE_CLUSTER=devnet
# VITE_CLUSTER=mainnet-beta

# ── RPC URL ───────────────────────────────────────────────
VITE_RPC_URL=https://api.devnet.solana.com
# VITE_RPC_URL=https://api.mainnet-beta.solana.com
# VITE_RPC_URL=https://your-custom-rpc.com

# ── Program ID ────────────────────────────────────────────
# Didapat setelah: anchor deploy
VITE_PROGRAM_ID=Co2fcVRVsGM4ZNGd5UMFVxdAvoRcpqoSpCvgdJzEUTjj

# ── Pool Authority Pubkey ─────────────────────────────────
# Didapat dari: solana-keygen pubkey /path/to/pool-authority.json
# POOL_PUBKEY dan VAULT_PUBKEY di-derive otomatis dari ini
# ORACLE_PUBKEY dan TREASURY_PUBKEY diambil dari pool account on-chain
VITE_POOL_AUTHORITY_PUBKEY=YOUR_POOL_AUTHORITY_PUBKEY_HERE

# ── Backend Services ──────────────────────────────────────
VITE_VERIFIKASI_URL=http://localhost:5050
VITE_KYC_URL=http://localhost:5052
