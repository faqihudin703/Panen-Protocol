# Panen Protocol — Rate Oracle Push Service
# Copy ke .env dan isi sesuai setup
# JANGAN commit file .env ke GitHub

# ── Cluster & RPC ─────────────────────────────────────────
RPC_URL=https://api.devnet.solana.com
# RPC_URL=https://api.mainnet-beta.solana.com
CLUSTER=devnet
# CLUSTER=mainnet-beta

# ── Program ───────────────────────────────────────────────
PROGRAM_ID=Co2fcVRVsGM4ZNGd5UMFVxdAvoRcpqoSpCvgdJzEUTjj

# ── Oracle PDA ────────────────────────────────────────────
# Didapat dari output: yarn tsx scripts/initialize.ts
# Format: RATE_ORACLE_PDA=<pubkey>
RATE_ORACLE_PDA=YOUR_RATE_ORACLE_PDA_HERE

# ── Oracle Keypair ────────────────────────────────────────
# Path ke oracle-authority.json
# Harus sama dengan oracle_authority yang dipass ke initialize_pool
# JANGAN share atau commit file keypair ini
ORACLE_KEYPAIR=./push.json

# ── Push Logic ────────────────────────────────────────────
# Minimum selisih IDR sebelum push on-chain (hindari push yang tidak perlu)
MIN_DIFF_IDR=10

# Paksa push walau rate tidak berubah (dalam jam)
HEARTBEAT_HOURS=24

# ── Schedule ──────────────────────────────────────────────
# Cron schedule untuk push otomatis
# Default: setiap hari 06:00 WIB
# Sesuaikan timezone server (UTC vs WIB/UTC+7)
CRON_SCHEDULE=0 6 * * *
