# Panen Protocol — Scripts Environment
# Copy ke .env dan isi sesuai setup lokal
# JANGAN commit file .env ke GitHub

# ── Network ───────────────────────────────────────────────
RPC_URL=https://api.devnet.solana.com
# RPC_URL=https://api.mainnet-beta.solana.com

# ── Program ID ────────────────────────────────────────────
# Didapat setelah: anchor deploy
PROGRAM_ID=Co2fcVRVsGM4ZNGd5UMFVxdAvoRcpqoSpCvgdJzEUTjj

# ── USDC Mint (opsional, auto-detect dari cluster) ────────
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── Keypair paths ─────────────────────────────────────────
# Generate dengan: solana-keygen new -o /path/to/keypair.json
POOL_AUTHORITY_KEYPAIR=/path/to/pool-authority.json
ORACLE_AUTHORITY_KEYPAIR=/path/to/oracle-authority.json
